# GunBroker REST API key — add as a GitHub Actions secret named GUNBROKER_DEV_KEY
# For local testing, copy this file to .env and fill in the value.
GUNBROKER_DEV_KEY=

# API base URL — sandbox for development, production when approved
# GUNBROKER_API_BASE=https://api.sandbox.gunbroker.com
# GUNBROKER_API_BASE=https://api.gunbroker.com

# Optional overrides
# GUNBROKER_SELLER_ID=1305569
# GUNBROKER_PAGE_SIZE=96
